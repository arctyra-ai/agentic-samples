# Agentic AI Engineering Curriculum - Environment Variables
# Copy this file: cp .env.example .env
# Then fill in your API keys below.

# Required: Anthropic API (primary LLM provider)
# Get your key at: https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: OpenAI API (secondary provider, for comparison exercises)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Optional: LangSmith (tracing and evaluation, free tier)
# Get your key at: https://smith.langchain.com
# Used from Week 6 onward
LANGCHAIN_API_KEY=ls-your-key-here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=agentic-training
